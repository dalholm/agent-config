{
  "memoryMode": "policy-only",
  "memoryPolicyStyle": "full",
  "memoryCharLimit": 5000,
  "userCharLimit": 5000,
  "projectCharLimit": 5000,
  "memoryDir": "__REPO__/pi/memory",
  "projectsMemoryDir": "__REPO__/pi/memory/projects-memory",
  "sessionSearch": { "variant": "legacy" },
  "llmModelOverride": "lmstudio/huihui-deepseek-v4-flash-abliterated-ds4",
  "llmThinkingOverride": "off",
  "nudgeInterval": 10,
  "nudgeToolCalls": 15,
  "reviewEnabled": true,
  "memoryOverflowStrategy": "auto-consolidate",
  "autoConsolidate": true,
  "correctionDetection": true,
  "flushOnCompact": true,
  "flushOnShutdown": true,
  "flushMinTurns": 6
}
