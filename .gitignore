.DS_Store

# Pi hermes-memory: SQLite session history is binary, large, and holds raw
# conversation logs — keep it out of git. The markdown memory/skills are tracked.
pi/memory/sessions.db
pi/memory/sessions.db-wal
pi/memory/sessions.db-shm

# Loop runtime artifacts — per-run logs, the single-instance lock, the cycle result.
loop/logs/
loop/.loop.lock/
loop/.cycle-result.json
loop/__pycache__/
